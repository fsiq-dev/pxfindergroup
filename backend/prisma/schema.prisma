generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Player {
  id            String   @id @default(uuid())
  characterName String
  world         String
  level         Int
  clan          String
  socketId      String   @unique
  createdAt     DateTime @default(now())

  ledRooms    Room[]       @relation("RoomLeader")
  memberships RoomMember[]
  messages    Message[]
}

model Room {
  id             String   @id @default(uuid())
  questId        String
  leaderId       String
  status         String   @default("waiting")
  maxPlayers     Int
  filterMinLevel Int
  filterWorld    String?
  filterClan     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  leader   Player       @relation("RoomLeader", fields: [leaderId], references: [id])
  members  RoomMember[]
  messages Message[]
}

model RoomMember {
  roomId   String
  playerId String
  joinedAt DateTime @default(now())

  room   Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id])

  @@id([roomId, playerId])
}

model Message {
  id         String   @id @default(uuid())
  roomId     String
  playerId   String
  playerName String
  content    String
  timestamp  DateTime @default(now())

  room   Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id])
}
