# ─── Backend ─────────────────────────────────────────────────────────────────
PORT=4000
CLIENT_URL=http://localhost:3000

# Redis (optional — queue runs in-memory if not set)
REDIS_URL=redis://localhost:6379

# PostgreSQL (optional — for persistence)
DATABASE_URL=postgresql://pxg:pxg_secret@localhost:5432/pxgfinder

# VAPID keys for Web Push Notifications
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_EMAIL=admin@yourapp.com

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://pxfindergroup-production.up.railway.app
NEXT_PUBLIC_WS_URL=https://pxfindergroup-production.up.railway.app
